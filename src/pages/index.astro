---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={SITE_TITLE}
			description={SITE_DESCRIPTION}
			canonicalPath="/"
			alternatePaths={{ ko: '/ko/', en: '/en/' }}
		/>
		<meta name="robots" content="noindex,follow" />
		<script is:inline>
			const saved = localStorage.getItem('preferredLocale');
			const locale = saved === 'ko' || saved === 'en'
				? saved
				: navigator.language.toLowerCase().startsWith('ko')
					? 'ko'
					: 'en';
			window.location.replace(`/${locale}/`);
		</script>
		<style>
			main {
				max-width: 720px;
				min-height: 70vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 1.5rem;
			}
			.locale-title {
				font-family: var(--font-mono);
				color: var(--green);
				margin: 0;
			}
			.locale-links {
				display: flex;
				gap: 0.75rem;
				font-family: var(--font-mono);
			}
			.locale-links a {
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 0.65rem 0.8rem;
				background: var(--panel);
			}
		</style>
	</head>
	<body>
		<main>
			<h1 class="locale-title">Joseph’s Working Notes</h1>
			<p>Choose a language. JavaScript will remember your manual choice and otherwise use your browser language.</p>
			<div class="locale-links">
				<a href="/ko/" data-locale="ko">KO</a>
				<a href="/en/" data-locale="en">EN</a>
			</div>
		</main>
		<script>
			document.querySelectorAll('[data-locale]').forEach((link) => {
				link.addEventListener('click', () => {
					const locale = link.getAttribute('data-locale');
					if (locale === 'ko' || locale === 'en') {
						localStorage.setItem('preferredLocale', locale);
					}
				});
			});
		</script>
	</body>
</html>
