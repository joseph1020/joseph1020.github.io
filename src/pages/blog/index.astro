---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`작업 기록 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.blog-intro {
				margin-bottom: 2.5rem;
				border-left: 2px solid var(--border);
				padding-left: 1rem;
			}
			.blog-title {
				font-size: 2rem;
				color: var(--text);
				margin-top: 0;
				margin-bottom: 0.75rem;
			}
			.blog-subtitle {
				font-family: var(--font-body);
				color: var(--muted);
				font-size: 0.95rem;
				line-height: 1.6;
				margin: 0;
			}
			
			.rgia-container {
				background-color: var(--panel);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				margin-bottom: 2rem;
			}
			.rgia-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.75rem 1rem;
				background-color: var(--bg);
				border-bottom: 1px solid var(--border);
				font-size: 0.85rem;
				color: var(--muted);
			}
			.rgia-prompt {
				color: var(--yellow);
			}
			.rgia-count {
				color: var(--green);
			}
			
			.results-grid {
				display: flex;
				flex-direction: column;
			}
			
			/* Desktop Table Styling using CSS Grid */
			.grid-row {
				display: grid;
				grid-template-columns: 220px 1.5fr 110px 2fr;
				gap: 1rem;
				padding: 0.75rem 1rem;
				border-bottom: 1px solid var(--border);
				align-items: center;
				font-size: 0.85rem;
			}
			.grid-row:last-child {
				border-bottom: none;
			}
			
			.grid-header-row {
				background-color: rgba(255, 255, 255, 0.02);
				color: var(--muted);
				font-weight: bold;
				border-bottom: 2px solid var(--border);
			}
			
			.grid-data-row {
				color: var(--text);
				text-decoration: none;
				transition: background-color 0.15s ease;
			}
			.grid-data-row:hover {
				background-color: rgba(255, 255, 255, 0.03);
				text-decoration: none;
			}
			.grid-data-row:hover .col-title {
				color: var(--green);
			}
			
			.col-path {
				color: var(--accent);
				overflow-wrap: anywhere;
			}
			.col-title {
				font-weight: 600;
				color: var(--text);
				font-family: var(--font-body);
				font-size: 0.95rem;
				word-break: keep-all;
			}
			.col-date {
				color: var(--muted);
			}
			.col-summary {
				color: var(--text);
				font-family: var(--font-body);
				font-size: 0.9rem;
				opacity: 0.85;
				word-break: keep-all;
			}
			.list-footnote {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: #4c566a;
				margin-top: 1rem;
				padding-left: 0.5rem;
			}

			@media (max-width: 820px) {
				.grid-header-row {
					display: none;
				}
				.grid-row {
					grid-template-columns: 1fr;
					gap: 0.35rem;
					padding: 1.25rem 1rem;
				}
				.col-path {
					font-size: 0.8rem;
				}
				.col-title {
					font-size: 1.1rem;
					margin-top: 0.1rem;
					margin-bottom: 0.25rem;
				}
				.col-date {
					font-size: 0.8rem;
					margin-bottom: 0.5rem;
				}
				.col-summary {
					font-size: 0.9rem;
					border-top: 1px dashed var(--border);
					padding-top: 0.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-intro">
				<h1 class="blog-title">작업 기록</h1>
				<p class="blog-subtitle">써본 것, 고장 난 것, 괜히 손댄 것.</p>
			</div>

			<div class="rgia-container">
				<div class="rgia-header">
					<span class="rgia-prompt">$ rgia --search "notes" --limit 20</span>
					<span class="rgia-count">{posts.length} {posts.length === 1 ? 'match' : 'matches'} in {posts.length} {posts.length === 1 ? 'file' : 'files'}</span>
				</div>
				<div class="results-grid">
					<div class="grid-row grid-header-row">
						<div>PATH</div>
						<div>TITLE</div>
						<div>DATE</div>
						<div>SUMMARY</div>
					</div>
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="grid-row grid-data-row">
							<div class="col-path">/blog/{post.id}/</div>
							<div class="col-title">{post.data.title}</div>
							<div class="col-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class="col-summary">
								{post.data.description}
							</div>
						</a>
					))}
				</div>
			</div>
			
			<div class="list-footnote">
				// 아직 한 편입니다.
			</div>
		</main>
		<Footer />
	</body>
</html>
