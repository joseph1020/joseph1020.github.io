---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const slug = 'codex-cua-background-usage';
const koPath = `/ko/blog/${slug}/`;
const enPath = `/en/blog/${slug}/`;

export function getStaticPaths() {
	return [{ params: { slug: 'codex-cua-background-usage' } }];
}
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`Moved - ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
			canonicalPath={koPath}
			alternatePaths={{ ko: koPath, en: enPath }}
		/>
		<meta http-equiv="refresh" content={`0; url=${koPath}`} />
		<style>
			main {
				max-width: 720px;
				min-height: 70vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 1rem;
			}
			.compat-title {
				font-family: var(--font-mono);
				color: var(--green);
				margin: 0;
			}
			.compat-links {
				display: flex;
				gap: 0.75rem;
				font-family: var(--font-mono);
			}
			.compat-links a {
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 0.65rem 0.8rem;
				background: var(--panel);
			}
		</style>
	</head>
	<body>
		<main>
			<h1 class="compat-title">Moved</h1>
			<p>This note now lives at the Korean localized URL. If your browser does not move automatically, choose a version below.</p>
			<div class="compat-links">
				<a href={koPath}>KO</a>
				<a href={enPath}>EN</a>
			</div>
		</main>
	</body>
</html>
