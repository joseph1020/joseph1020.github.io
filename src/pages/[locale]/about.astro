---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { locales, type Locale, ui } from '../../i18n/ui';

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const copy = ui[locale];
const alternatePaths = { ko: '/ko/about/', en: '/en/about/' };
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={`About - ${SITE_TITLE}`} description={copy.siteDescription} locale={locale} canonicalPath={`/${locale}/about/`} alternatePaths={alternatePaths} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 3rem 1.5rem;
			}
			.help-title {
				font-family: var(--font-mono);
				font-size: 1.5rem;
				color: var(--green);
				margin-top: 0;
				margin-bottom: 2.5rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.help-prompt {
				color: var(--muted);
				user-select: none;
			}
			.help-section {
				margin-bottom: 2rem;
				display: grid;
				grid-template-columns: 180px 1fr;
				gap: 1.5rem;
			}
			.section-name {
				font-family: var(--font-mono);
				font-weight: 700;
				color: var(--yellow);
				font-size: 0.95rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin: 0;
				padding-top: 0.1rem;
			}
			.section-content {
				margin: 0;
				color: var(--text);
				font-size: 1rem;
				line-height: 1.8;
			}
			.section-content p {
				margin: 0 0 1rem 0;
			}
			.section-content p:last-child {
				margin-bottom: 0;
			}
			.signature-block {
				margin-top: 4rem;
				border-top: 1px dashed var(--border);
				padding-top: 2rem;
			}
			.signature-text {
				font-size: 0.85rem;
				line-height: 1.6;
				color: #4c566a;
				margin: 0;
			}
			.exit-code {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: #4c566a;
				margin-top: 1rem;
			}

			@media (max-width: 640px) {
				.help-section {
					grid-template-columns: 1fr;
					gap: 0.5rem;
					margin-bottom: 2.5rem;
				}
				.section-name {
					border-bottom: 1px solid var(--border);
					padding-bottom: 0.25rem;
				}
				main {
					padding: 2rem 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header locale={locale} alternatePaths={alternatePaths} />
		<main>
			<h1 class="help-title">
				<span class="help-prompt">$</span> joseph --help
			</h1>

			<div class="help-section">
				<h2 class="section-name">NAME</h2>
				<div class="section-content">
					<p>Joseph Kim</p>
				</div>
			</div>

			<div class="help-section">
				<h2 class="section-name">DESCRIPTION</h2>
				<div class="section-content">
					<p>{copy.aboutDescription}</p>
				</div>
			</div>

			<div class="help-section">
				<h2 class="section-name">INTERESTS</h2>
				<div class="section-content">
					<p>{copy.aboutInterests}</p>
				</div>
			</div>

			<div class="help-section">
				<h2 class="section-name">PREFERENCES</h2>
				<div class="section-content">
					{copy.aboutPreferences.map((line) => <p>{line}</p>)}
				</div>
			</div>

			<div class="help-section">
				<h2 class="section-name">NOTES</h2>
				<div class="section-content">
					<p>{copy.aboutNotes}</p>
				</div>
			</div>

			<div class="signature-block">
				{copy.signature.map((line) => <p class="signature-text">{line}</p>)}
				<div class="exit-code">
					// exit code: 0
				</div>
			</div>
		</main>
		<Footer locale={locale} />
	</body>
</html>
