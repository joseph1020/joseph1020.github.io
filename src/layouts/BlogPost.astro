---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { Locale } from '../i18n/ui';
import { blogPath } from '../i18n/ui';

type Props = CollectionEntry<'blog'>['data'] & {
	locale: Locale;
	slug: string;
	alternatePaths: Partial<Record<Locale, string>>;
	availableLocales: Locale[];
};

const { title, description, pubDate, status, source, sourceUrl, locale, slug, alternatePaths, availableLocales } = Astro.props;
const publicPath = blogPath(locale, slug);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={title} description={description} locale={locale} canonicalPath={publicPath} alternatePaths={alternatePaths} />
		<style>
			main {
				width: 100%;
				max-width: 960px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
			}
			.post-container {
				width: 100%;
			}
			.terminal-meta {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--muted);
				margin-bottom: 2rem;
				border: 1px solid var(--border);
				background-color: var(--panel);
				border-radius: 4px;
				padding: 1rem;
			}
			.meta-line {
				margin-bottom: 0.25rem;
			}
			.meta-line:last-child {
				margin-bottom: 0;
			}
			.meta-label {
				color: var(--yellow);
				margin-right: 0.5rem;
			}
			.meta-val a {
				color: var(--accent);
			}
			.post-title {
				font-size: 2.25rem;
				line-height: 1.3;
				margin-top: 1.5rem;
				margin-bottom: 1.5rem;
				word-break: keep-all;
				overflow-wrap: anywhere;
				border-bottom: 1px solid var(--border);
				padding-bottom: 1rem;
			}
			.prose-body {
				line-height: 1.8;
				font-size: 1.05rem;
				color: var(--text);
			}
			:global(.prose-body p) {
				margin-bottom: 1.5rem;
			}
			/* Code and blockquote custom inside post */
			:global(.prose-body pre) {
				margin: 2rem 0;
			}
			.end-marker {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--muted);
				margin-top: 4rem;
				padding-top: 1.5rem;
				border-top: 1px dashed var(--border);
				letter-spacing: 0.05em;
			}
			@media (max-width: 720px) {
				.post-title {
					font-size: 1.75rem;
				}
				main {
					padding: 1.5rem 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header locale={locale} alternatePaths={alternatePaths} availableLocales={availableLocales} />
		<main>
			<article class="post-container">
				<div class="terminal-meta">
					<div class="meta-line"><span class="meta-label">PATH:</span> {publicPath}</div>
					<div class="meta-line"><span class="meta-label">DATE:</span> <FormattedDate date={pubDate} /></div>
					{status && <div class="meta-line"><span class="meta-label">STATUS:</span> {status}</div>}
					{source && (
						<div class="meta-line">
							<span class="meta-label">SOURCE:</span>
							<span class="meta-val">
								{sourceUrl ? <a href={sourceUrl} target="_blank" rel="noopener noreferrer">{source}</a> : source}
							</span>
						</div>
					)}
				</div>
				<h1 class="post-title">{title}</h1>
				<div class="prose-body">
					<slot />
				</div>
				<div class="end-marker">
					// end of note
				</div>
			</article>
		</main>
		<Footer locale={locale} />
	</body>
</html>
