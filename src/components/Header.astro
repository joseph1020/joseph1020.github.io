---
import { SITE_TITLE } from '../consts';
import type { Locale } from '../i18n/ui';
import HeaderLink from './HeaderLink.astro';

interface Props {
	locale: Locale;
	availableLocales?: Locale[];
	alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, availableLocales = ['ko', 'en'], alternatePaths = {} } = Astro.props;
const switchers = availableLocales
	.map((targetLocale) => ({
		locale: targetLocale,
		href: alternatePaths[targetLocale],
		label: targetLocale.toUpperCase(),
		active: targetLocale === locale,
	}))
	.filter((item) => item.href);
---

<header>
	<nav>
		<h2><a href={`/${locale}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`/${locale}/`}>Home</HeaderLink>
			<HeaderLink href={`/${locale}/blog/`}>Blog</HeaderLink>
			<HeaderLink href={`/${locale}/about/`}>About</HeaderLink>
		</div>
		<div class="utility-links">
			<div class="language-links" aria-label="Language">
				{switchers.map((item) => (
					item.active ? (
						<span class="language-link active" aria-current="true">{item.label}</span>
					) : (
						<a class="language-link" href={item.href} data-locale={item.locale}>{item.label}</a>
					)
				))}
			</div>
			<a href="https://github.com/joseph1020" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Go to Joseph's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
	<script>
		document.querySelectorAll('[data-locale]').forEach((link) => {
			link.addEventListener('click', () => {
				const locale = link.getAttribute('data-locale');
				if (locale === 'ko' || locale === 'en') {
					localStorage.setItem('preferredLocale', locale);
				}
			});
		});
	</script>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5rem;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}
	h2 {
		margin: 0;
		font-size: 1.1rem;
		font-family: var(--font-mono);
	}

	h2 a {
		text-decoration: none;
		color: var(--text);
	}
	h2 a:hover {
		color: var(--green);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 4rem;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		gap: 0.5rem;
	}
	:global(.internal-links a) {
		padding: 0.5rem 0.75rem;
		color: var(--muted);
		text-decoration: none;
		font-family: var(--font-mono);
		font-size: 0.95rem;
		border-radius: 4px;
		transition: all 0.15s ease;
	}
	:global(.internal-links a:hover) {
		color: var(--text);
		background-color: var(--panel);
		text-decoration: none;
	}
	:global(.internal-links a.active) {
		color: var(--green);
		background-color: var(--panel);
		font-weight: 600;
	}
	.utility-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.language-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
	}
	.language-link {
		color: var(--muted);
		padding: 0.35rem 0.45rem;
		border-radius: 4px;
		text-decoration: none;
	}
	.language-link:hover {
		color: var(--text);
		background-color: var(--panel);
		text-decoration: none;
	}
	.language-link.active {
		color: var(--green);
		background-color: var(--panel);
	}
	.utility-links > a {
		color: var(--muted);
		display: flex;
		align-items: center;
		padding: 0.5rem;
		border-radius: 4px;
		transition: all 0.15s ease;
	}
	.utility-links > a:hover {
		color: var(--text);
		background-color: var(--panel);
	}
	@media (max-width: 640px) {
		header {
			padding: 0 1rem;
		}
		nav {
			height: auto;
			min-height: 4rem;
			flex-wrap: wrap;
			padding: 0.75rem 0;
		}
		.internal-links {
			order: 3;
			width: 100%;
			overflow-x: auto;
		}
	}
</style>
