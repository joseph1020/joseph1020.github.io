---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname;
const normalizedHref = href.endsWith('/') ? href : `${href}/`;
const isLocaleHome = /^\/(?:ko|en)\/$/.test(normalizedHref);
const isActive = pathname === normalizedHref || (!isLocaleHome && normalizedHref !== '/' && pathname.startsWith(normalizedHref));
const classes = [className, isActive ? 'active' : undefined].filter(Boolean).join(' ');
---

<a href={href} class={classes} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
