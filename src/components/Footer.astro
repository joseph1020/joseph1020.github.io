---
const today = new Date();
---

<footer>
	<div class="footer-info">
		&copy; {today.getFullYear()} Joseph Kim.
		<a href="https://github.com/joseph1020" target="_blank" rel="noopener noreferrer" class="github-link">GitHub</a>
	</div>
	<div class="signature">
		돌아는 갑니다.<br />
		계속 쓸지는 모르겠습니다.
	</div>
</footer>
<style>
	footer {
		padding: 3rem 1.5rem;
		background: var(--bg);
		border-top: 1px solid var(--border);
		color: var(--muted);
		text-align: center;
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}
	.footer-info {
		margin-bottom: 1rem;
	}
	.github-link {
		color: var(--muted);
		text-decoration: underline;
		margin-left: 0.5rem;
	}
	.github-link:hover {
		color: var(--text);
	}
	.signature {
		font-family: var(--font-body);
		font-size: 0.8rem;
		line-height: 1.6;
		color: #4c566a; /* more muted grey */
		margin-top: 1.5rem;
		text-align: center;
	}
</style>
